# Worker (Quantum 2) container image
FROM python:3.12-slim

WORKDIR /app

COPY requirements.base.txt .
COPY requirements.analysis.txt .
RUN pip install --no-cache-dir -r requirements.base.txt -r requirements.analysis.txt

COPY . .

# The worker is a separate process from the backend service
CMD ["python", "-m", "workers.analysis_worker"]
